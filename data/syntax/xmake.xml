			<item>add_plugindirs</item>
			<item>add_packagedirs</item>
			<item>get_config</item>
			<item>set_config</item>
			<item>task_end</item>
			<item>rule_end</item>
			<item>package_end</item>
			<!-- Condition functions -->
			<item>is_os</item>
